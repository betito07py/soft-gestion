<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup>
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
    <!--
      Conexión a SQL Server (ADO.NET, sin Entity Framework).
      - SoftGestionPrincipal: base operativa del ERP (repositorios por defecto vía ConfiguracionConexion / ConexionSqlServer).
      - ConfigServer: reservada para servidor de configuración si se usa más adelante.
      Ajustar Data Source, Initial Catalog, autenticación (Integrated Security o User Id / Password).
    -->
    <connectionStrings>
        <add name="ConfigServer"
             connectionString="Data Source=.;Initial Catalog=SoftGestionConfig;Integrated Security=True;TrustServerCertificate=True"
             providerName="System.Data.SqlClient" />
        <add name="SoftGestionPrincipal"
             connectionString="Data Source=.;Initial Catalog=SoftGestion;Integrated Security=True;TrustServerCertificate=True"
             providerName="System.Data.SqlClient" />
    </connectionStrings>
</configuration>
